{
  "schema_version": 1,
  "plugins": [
    {
      "id": "msopgen.opdesc_json",
      "type": "builder",
      "name": "算子描述 JSON 生成器（msOpGen 第一步）",
      "group": "msOpGen / 描述文件",
      "emit": "json",
      "description": "msOpGen 生成工程前的第一步：按算子名、输入/输出张量、属性生成可喂给 msopgen gen 的算子描述 JSON。下拉框已锁死合法值；切到 MindSpore 模式会自动隐藏 format 并换成合并写法的 dtype。生成后用「保存到本地」存好，再用文件管理器/发送到板子传上去。",
      "basic_fields": [
        {"key": "op", "label": "算子名", "type": "text", "default": "AddCustom"},
        {"key": "mode", "label": "模式", "type": "choice",
         "options": ["IR", "MindSpore"], "default": "IR",
         "control_only": true, "rerender_on_change": true,
         "option_hints": {
           "IR": "通用/Ascend C/TensorFlow/ONNX/PyTorch。format 与 dtype 分开写（format=[\"ND\"], type=[\"fp16\"]）。不确定就用它。",
           "MindSpore": "华为 MindSpore 框架专用。没有 format 字段，排布和类型合并写在 type 里（如 I8_NCHW=int8+NCHW）。"
         }}
      ],
      "repeat_sections": [
        {
          "key": "input_desc", "label": "输入张量",
          "legend": "name=张量名 ｜ param_type: required必填 / optional可选 / dynamic动态(数量不定) ｜ format=内存排布(NCHW=批/通道/高/宽, ND=任意维度) ｜ dtype=数据类型。可逗号分隔填多个。",
          "fields": [
            {"key": "name", "type": "text", "label": "名字", "default": "x"},
            {"key": "param_type", "type": "choice", "label": "参数类型",
             "options": ["required", "optional", "dynamic"], "default": "required"},
            {"key": "format", "type": "choice", "label": "format",
             "options": ["NCHW", "NHWC", "ND", "NC1HWC0"], "default": "ND",
             "emit": "list", "omit_when": {"basic": "mode", "equals": "MindSpore"}},
            {"key": "type", "type": "choice", "label": "dtype",
             "default": "fp16", "emit": "list",
             "options_by": {"basic": "mode", "map": {
               "IR": ["fp16", "fp32", "int8", "int32", "uint8", "bool"],
               "MindSpore": ["F16_NCHW", "F16_NHWC", "F32_NCHW", "F32_NHWC",
                             "I8_NCHW", "I8_NHWC", "I32_NCHW", "U8_NCHW", "BOOL_NCHW"]
             }}}
          ]
        },
        {
          "key": "output_desc", "label": "输出张量",
          "legend": "字段含义同输入张量。",
          "fields": [
            {"key": "name", "type": "text", "label": "名字", "default": "y"},
            {"key": "param_type", "type": "choice", "label": "参数类型",
             "options": ["required", "optional", "dynamic"], "default": "required"},
            {"key": "format", "type": "choice", "label": "format",
             "options": ["NCHW", "NHWC", "ND", "NC1HWC0"], "default": "ND",
             "emit": "list", "omit_when": {"basic": "mode", "equals": "MindSpore"}},
            {"key": "type", "type": "choice", "label": "dtype",
             "default": "fp16", "emit": "list",
             "options_by": {"basic": "mode", "map": {
               "IR": ["fp16", "fp32", "int8", "int32", "uint8", "bool"],
               "MindSpore": ["F16_NCHW", "F16_NHWC", "F32_NCHW", "F32_NHWC",
                             "I8_NCHW", "I8_NHWC", "I32_NCHW", "U8_NCHW", "BOOL_NCHW"]
             }}}
          ]
        },
        {
          "key": "attr", "label": "属性（可选，不填就不生成）",
          "legend": "name=属性名 ｜ param_type: required必填 / optional可选（属性不能用 dynamic）｜ type=属性类型(list_int=整数列表如strides, int=单个整数)。留空名字这一行不会写进 JSON。",
          "fields": [
            {"key": "name", "type": "text", "label": "名字", "default": ""},
            {"key": "param_type", "type": "choice", "label": "参数类型",
             "options": ["required", "optional"], "default": "required"},
            {"key": "type", "type": "choice", "label": "类型",
             "options": ["list_int", "int", "float", "bool", "str", "list_float"],
             "default": "list_int"}
          ]
        }
      ]
    },
    {
      "id": "msopst.case_json",
      "type": "builder",
      "name": "msOpST case JSON 生成器（run 前补测试配置）",
      "group": "msOpST / 测试用例",
      "emit": "json",
      "description": "接在 msopst create 后面用：按算子名、case 名、输入/输出 shape、dtype、format 生成 msopst run 可用的测试 case JSON。我们板子实测 run 的 -soc 用 Ascend310B1，不是 ascend310b。",
      "basic_fields": [
        {"key": "op", "label": "算子名", "type": "text", "default": "AddCustom"},
        {"key": "case_name", "label": "case 名称", "type": "text", "default": "add_custom_fp16_2048"},
        {"key": "expect", "label": "预期结果", "type": "choice",
         "options": ["success", "failed"], "default": "success"},
        {"key": "error_threshold", "label": "误差阈值（可空）", "type": "text", "default": ""},
        {"key": "calc_expect_func_file", "label": "期望值脚本（可空）", "type": "text", "default": ""}
      ],
      "repeat_sections": [
        {
          "key": "input_desc", "label": "输入张量",
          "legend": "name=输入名 ｜ shape=测试形状，多个维度用逗号分隔，如 3,16384 ｜ dtype/format 必填。随机数据和值域可先留空。",
          "default_rows": [
            {"name": "x", "shape": "2048", "type": "float16", "format": "ND"},
            {"name": "y", "shape": "2048", "type": "float16", "format": "ND"}
          ],
          "fields": [
            {"key": "name", "type": "text", "label": "名字", "default": "x"},
            {"key": "shape", "type": "text", "label": "shape", "default": "2048", "emit": "list_int"},
            {"key": "type", "type": "choice", "label": "dtype",
             "options": ["float16", "float32", "int8", "int32", "uint8", "bool"], "default": "float16"},
            {"key": "format", "type": "choice", "label": "format",
             "options": ["ND", "NCHW", "NHWC", "NC1HWC0"], "default": "ND"},
            {"key": "data_distribute", "type": "choice", "label": "随机数据",
             "options": ["", "uniform", "normal"], "default": ""},
            {"key": "value_range", "type": "text", "label": "值域", "default": "", "emit": "list_float"}
          ]
        },
        {
          "key": "output_desc", "label": "输出张量",
          "legend": "字段含义同输入张量。输出通常只需要 name、shape、dtype、format。",
          "default_rows": [
            {"name": "z", "shape": "2048", "type": "float16", "format": "ND"}
          ],
          "fields": [
            {"key": "name", "type": "text", "label": "名字", "default": "z"},
            {"key": "shape", "type": "text", "label": "shape", "default": "2048", "emit": "list_int"},
            {"key": "type", "type": "choice", "label": "dtype",
             "options": ["float16", "float32", "int8", "int32", "uint8", "bool"], "default": "float16"},
            {"key": "format", "type": "choice", "label": "format",
             "options": ["ND", "NCHW", "NHWC", "NC1HWC0"], "default": "ND"}
          ]
        }
      ]
    }
  ]
}
